# OmniVia Docker Stack Environment Configuration
# Copy to .env and adjust for your local setup

# =============================================================================
# Database Configuration
# =============================================================================

# Path to the SQLite database file (inside container)
OMNIVIA_DB_PATH=/data/omnivia.sqlite

# =============================================================================
# Vector Database Configuration
# =============================================================================

# Qdrant service name in docker-compose (internal hostname)
QDRANT_URL=http://qdrant:6333

# =============================================================================
# MCP Server Configuration
# =============================================================================

# API service hostname (internal docker network)
OMNIVIA_API_URL=http://api:8080

# =============================================================================
# API Configuration
# =============================================================================

# Running locally via Docker
OMNIVIA_MODE=local

# =============================================================================
# Local Development Notes
# =============================================================================
# - Run: docker compose -f docker-compose.local.yml up
# - API: http://localhost:8080
# - MCP: http://localhost:8081
# - Qdrant: http://localhost:6333 (REST), :6334 (gRPC)
# - Never commit .env files with real credentials