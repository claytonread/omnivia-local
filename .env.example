# OmniVia Environment Configuration
# Copy to .env and fill in values for local development

# =============================================================================
# Database Configuration
# =============================================================================

# Path to the SQLite database file
# Default: data/omnivia.sqlite relative to the repository root
OMNIVIA_DB_PATH=/data/omnivia.sqlite

# =============================================================================
# Vector Database Configuration
# =============================================================================

# Qdrant server URL (used by the API service)
# Default for Docker: http://qdrant:6333
# Default for local: http://localhost:6333
QDRANT_URL=http://localhost:6333

# =============================================================================
# MCP Server Configuration
# =============================================================================

# API base URL for the MCP server to connect to
# Default for Docker: http://api:8080
# Default for local: http://localhost:8080
OMNIVIA_API_URL=http://localhost:8080

# =============================================================================
# API Configuration
# =============================================================================

# Operating mode: local | cloud
OMNIVIA_MODE=local

# =============================================================================
# Local Development Notes
# =============================================================================
# - Run `docker compose -f infra/docker/docker-compose.local.yml up` to start the stack
# - API runs on port 8080, MCP server on port 8081, Qdrant on ports 6333/6334
# - Data directory is mounted at /data in containers (mapped to ./data in repo)
# - Never commit the .env file with real credentials